{
    "name": "hexlet/code",
    "description": "Page analyzer",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6",
        "guzzlehttp/guzzle": "^7.8",
        "slim/php-view": "^3.3",
        "vlucas/valitron": "^1.4",
        "nesbot/carbon": "^3.11",
        "slim/flash": "^0.4.0",
        "illuminate/support": "^13.13",
        "symfony/dom-crawler": "^7.4",
        "symfony/css-selector": "^7.4"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.7",
        "phpunit/phpunit": "^9.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "lint": "phpcs --standard=PSR12 --ignore=vendor/* --extensions=php .",
        "test": "phpunit tests/"
    }
}
